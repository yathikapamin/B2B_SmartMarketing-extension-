# Email Configuration
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here

# SMTP Configuration (Gmail by default)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Server Configuration
PORT=3000

# Instructions:
# 1. Copy this file to .env
# 2. Replace EMAIL_USER with your Gmail address
# 3. For EMAIL_PASSWORD, use Gmail App Password (not your regular password)
#    - Go to: https://myaccount.google.com/apppasswords
#    - Generate a new App Password
#    - Use that 16-character password here
# 4. For other email providers, update SMTP_HOST and SMTP_PORT accordingly
